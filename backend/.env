# Customer Segmentation API Configuration
# Development environment settings

SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_ENVIRONMENT=development

# Allow frontend on common development ports
CORS_ORIGINS=http://localhost:3000,http://localhost:8001,http://localhost:5500,http://127.0.0.1:5500,http://127.0.0.1:8001,file://

# Dataset location
DATASET_PATH=../Customers_dataset.csv

# Input validation ranges
INCOME_MIN=1
INCOME_MAX=1000000
SPENDING_SCORE_MIN=1
SPENDING_SCORE_MAX=100
FREQUENCY_MIN=0
FREQUENCY_MAX=365
RECENCY_MIN=0
RECENCY_MAX=3650
MONETARY_MIN=0
MONETARY_MAX=1000000
