# Customer Segmentation API Configuration
# Copy this file to .env and adjust values for your environment

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_ENVIRONMENT=development

# CORS Origins (comma-separated, no spaces)
# For development: allow localhost on different ports
# For production: specify your domain
CORS_ORIGINS=http://localhost:3000,http://localhost:8001,http://localhost:5500

# Data Configuration
DATASET_PATH=../Customers_dataset.csv

# Input Validation Constraints
# Income constraints
INCOME_MIN=1
INCOME_MAX=1000000

# Spending Score constraints (typically 1-100)
SPENDING_SCORE_MIN=1
SPENDING_SCORE_MAX=100

# Frequency constraints (purchases per year, 0-365)
FREQUENCY_MIN=0
FREQUENCY_MAX=365

# Recency constraints (days since last purchase, 0-3650 = 10 years)
RECENCY_MIN=0
RECENCY_MAX=3650

# Monetary constraints (total spending)
MONETARY_MIN=0
MONETARY_MAX=1000000
